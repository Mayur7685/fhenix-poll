# ─── Chain ────────────────────────────────────────────────────────────────────
# 421614 = Arbitrum Sepolia | 31337 = localCofhe (hardhat)
VITE_CHAIN_ID=421614

# ─── RPC ──────────────────────────────────────────────────────────────────────
# Optional override — defaults to public Arbitrum Sepolia RPC
# VITE_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── Contract ─────────────────────────────────────────────────────────────────
# Deployed FhenixPoll address (auto-written by deploy script into src/lib/abi.json)
VITE_CONTRACT_ADDRESS=0x2b110622725eE01e9c5a9704Afd2816619d6d573

# L2 block number when the contract was deployed on Arbitrum Sepolia.
# Required: the L2 chain has ~260 M blocks; getLogs from 0 hits RPC range limits.
# Find it in the deploy tx receipt, or on Arbiscan under the contract creation tx.
# VITE_DEPLOYMENT_BLOCK=300000000

# ─── Verifier Backend ─────────────────────────────────────────────────────────
# Local: http://localhost:3001
# Live:  https://zkpoll-verifier.onrender.com
VITE_VERIFIER_URL=http://localhost:3001

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Your Pinata dedicated gateway (reads are public, no auth needed from frontend)
VITE_PINATA_GATEWAY=https://<your-subdomain>.mypinata.cloud

# ─── WalletConnect ────────────────────────────────────────────────────────────
VITE_WC_PROJECT_ID=fhenixpoll-dev
